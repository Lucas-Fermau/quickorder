# PostgreSQL connection string
# Neon (recommended): paste connection string from Neon dashboard
# Local: postgresql://user:pass@localhost:5432/quickorder
DATABASE_URL="postgresql://user:pass@localhost:5432/quickorder"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-me-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS - frontend origin (comma-separated for multiple)
CLIENT_ORIGIN="http://localhost:5173"
