# MongoDB connection string
# Local: mongodb://localhost:27017/quickorder
# Atlas: mongodb+srv://<user>:<pass>@<cluster>/quickorder?retryWrites=true&w=majority
MONGODB_URI="mongodb://localhost:27017/quickorder"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-me-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS - frontend origin (comma-separated for multiple)
CLIENT_ORIGIN="http://localhost:5173"
